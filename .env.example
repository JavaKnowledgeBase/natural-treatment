# All variables are optional. Omit any of them and the affected service runs
# in MOCK_MODE (clearly labeled canned output) instead of failing.

# Redis (Tier 1 + Tier 2 cache). Defaults to the local docker-compose redis.
REDIS_URL=redis://redis:6379/0

# Anthropic Claude — powers the intake, mapping, and explanation agents.
# Unset -> those agents fall back to deterministic mock responses.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
# Request timeout for each Claude call. Also the boundary for the
# runtime-failure fallback (timeout/rate-limit/network error -> same
# deterministic template mock mode uses, not a 500).
ANTHROPIC_TIMEOUT_SECONDS=20

# Resend — powers the end-of-session email export.
# Unset -> the email service logs the rendered email instead of sending it.
RESEND_API_KEY=
RESEND_FROM_ADDRESS=onboarding@resend.dev

# Gateway (the only browser-facing service)
# Origins allowed to call the gateway from a browser. Comma-separated if more than one.
CORS_ALLOW_ORIGINS=http://localhost:3000
# Per-client-IP requests/minute before the gateway returns 429.
GATEWAY_RATE_LIMIT_PER_MINUTE=60

# Session behavior
SESSION_IDLE_TIMEOUT_SECONDS=1800
